# Django
DJANGO_SETTINGS_MODULE=config.settings.local
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Database
# Local example:
# DATABASE_URL=postgres://noshiro:password@127.0.0.1:5432/noshiro_db
# Production should use its real host and credentials.
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/noshiro_db

# CORS / CSRF
CORS_ALLOW_ALL_ORIGINS=True
CORS_ALLOW_CREDENTIALS=True
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# JWT refresh cookie
JWT_REFRESH_COOKIE_NAME=noshiro_refresh
JWT_REFRESH_COOKIE_PATH=/api/users/
JWT_REFRESH_COOKIE_DOMAIN=
JWT_REFRESH_COOKIE_SECURE=False
JWT_REFRESH_COOKIE_SAMESITE=Lax
JWT_REFRESH_COOKIE_MAX_AGE=2592000

# MinIO / avatar storage
# MINIO_ENDPOINT can be a raw host:port or a URL. If it has https://, HTTPS is inferred.
MINIO_ENDPOINT=127.0.0.1:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_HTTPS=False
MINIO_BUCKET=noshiro-avatars
MINIO_PUBLIC_URL=http://127.0.0.1:9000
AVATAR_MAX_UPLOAD_SIZE=10485760
AVATAR_ALLOWED_CONTENT_TYPES=image/jpeg,image/png,image/webp

# Bangumi
BANGUMI_API_BASE_URL=https://api.bgm.tv
BANGUMI_API_KEY=
BANGUMI_USER_AGENT="Noshiro_5794/noshiro_db (https://github.com/LHYHENRY/noshiro_db_backend)"
BANGUMI_TIMEOUT=30

# Sync
SYNC_INCREMENTAL_SUBJECT_BATCH_SIZE=1000
SYNC_INCREMENTAL_MAX_CONSECUTIVE_ERRORS=20
SYNC_INCREMENTAL_MAX_CONSECUTIVE_SKIPS=50
SYNC_CALENDAR_CRON_HOUR=3
SYNC_CALENDAR_CRON_MINUTE=30
SYNC_INCREMENTAL_CRON_HOUR=4
SYNC_INCREMENTAL_CRON_MINUTE=0

# Celery / Redis
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/1

# Email
RESEND_API_KEY=
EMAIL_FROM=noreply@noshiro.moe

# AI agent API
AI_AGENT_API_BASE_URL=https://api.siliconflow.cn/v1/chat/completions
AI_AGENT_API_KEY=
AI_AGENT_MODEL=Pro/zai-org/GLM-4.7
AI_AGENT_TIMEOUT=30
